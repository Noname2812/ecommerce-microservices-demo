{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://yourapp.com",
      "https://admin.yourapp.com"
    ],
    "AllowCredentials": true,
    "PreflightMaxAgeSeconds": 3600
  },
  "Kestrel": {
    "Edge": {
      "HttpsEnabled": true,
      "ListenAddress": "*",
      "HttpsPort": 8443,
      "PfxPath": "/run/secrets/gateway-tls.pfx"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "UrbanX.Gateway"
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "${OTEL_COLLECTOR_ENDPOINT}",
  "IdentityServer": {
    "Authority": "${IDENTITY_SERVER_URL}",
    "Audience": "urbanx-api"
  }
}
