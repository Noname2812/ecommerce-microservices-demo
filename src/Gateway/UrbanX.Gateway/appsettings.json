{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://localhost:5173",
      "http://localhost:5174",
      "https://localhost:5174"
    ],
    "AllowedHeaders": [ "Authorization", "Content-Type", "X-Request-Id" ],
    "ExposedHeaders": [ "X-Request-Id", "X-RateLimit-Remaining" ],
    "AllowCredentials": true,
    "PreflightMaxAgeSeconds": 3600
  },
  "Kestrel": {
    "Edge": {
      "HttpsEnabled": false
    }
  },
  "Jwt": {
    "Authority": "http://localhost:5005",
    "Audience": "urbanx-api"
  },
  "IdentityServer": {
    "Authority": "http://localhost:5005",
    "Audience": "urbanx-api"
  },
  "RateLimit": {
    "SlidingWindowSegments": 6,
    "GlobalPerIp": { "PermitLimit": 1000, "WindowSeconds": 60 },
    "AuthEndpoints": { "PermitLimit": 10, "WindowSeconds": 60 },
    "AuthenticatedUser": { "PermitLimit": 300, "WindowSeconds": 60 },
    "SearchEndpoints": { "PermitLimit": 60, "WindowSeconds": 60 },
    "WriteOperations": { "PermitLimit": 50, "WindowSeconds": 60 }
  },
  "GatewayRbac": {
    "Public": [],
    "Rules": [],
    "FallThroughToAuthenticatedOnly": true
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/catalog/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/{cart,orders}/{**catch-all}"
        }
      },
      "merchant-route": {
        "ClusterId": "merchant-cluster",
        "Match": {
          "Path": "/api/merchants/{**catch-all}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}"
        }
      },
      "identity-account-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/account/{**catch-all}"
        }
      },
      "identity-connect-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      },
      "identity-wellknown-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/.well-known/{**catch-all}"
        }
      },
      "identity-signin-google-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/signin-google"
        }
      },
      "identity-api-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/identity/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5290"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "merchant-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5006"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      }
    }
  }
}
