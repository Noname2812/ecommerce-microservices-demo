{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "Inventory": "http://inventory-service"
  },
  "Catalog": {
    "Messaging": {
      "ProductProjection": {
        "Retry": {
          "RetryLimit": 3,
          "MinIntervalMs": 200,
          "MaxIntervalMs": 2000,
          "IntervalDeltaMs": 500
        },
        "PrefetchCount": 16,
        "ConcurrentMessageLimit": 8
      }
    }
  }
}
