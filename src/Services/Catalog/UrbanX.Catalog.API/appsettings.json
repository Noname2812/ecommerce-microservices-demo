{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "Outbox": {
      "DefaultTopic": "catalog.product.events",
      "BatchSize": 50,
      "PollingIntervalMs": 5000,
      "MaxRetries": 3
    }
  }
}
