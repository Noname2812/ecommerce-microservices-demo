{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdentityServer": {
    "Audience": "urbanx-api"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "Inventory": {
    "Messaging": {
      "InventoryReleaseRequested": {
        "QueueName": "inventory-i-inventory-release-requested",
        "Retry": {
          "Intervals": 3,
          "IntervalSeconds": 5
        }
      },
      "ReserveInventoryRequested": {
        "Retry": {
          "RetryLimit": 3,
          "MinIntervalMs": 200,
          "MaxIntervalMs": 2000,
          "IntervalDeltaMs": 500
        },
        "PrefetchCount": 32,
        "ConcurrentMessageLimit": 16
      }
    },
    "Jobs": {
      "ReleaseExpiredReservations": {
        "BatchSize": 200,
        "CronExpression": "*/2 * * * *"
      }
    }
  }
}
