{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdentityServer": {
    "Audience": "urbanx-api"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "PlaceOrder": {
    "MaxNormalPendingPerUser": 1,
    "MaxSalesPendingPerUser": 3,
    "PendingSlotTtlMinutes": 30,
    "CouponLockTtlSeconds": 960,
    "PriceMismatchTolerance": 0.01
  },
  "Shipping": {
    "SupportedRegions": [
      "hanoi:badinh",
      "hanoi:caugiay",
      "hanoi:thanhxuan",
      "hochiminh:district 1",
      "hochiminh:district 7",
      "danang:haichau"
    ]
  },
  "Order": {
    "TicketCache": {
      "TerminalTtlSeconds": 300,
      "NonTerminalTtlSeconds": 2
    },
    "Payment": {
      "NormalOrderExpiryMinutes": 30,
      "SalesOrderExpiryMinutes": 15,
      "StepTimeoutSeconds": 30
    },
    "Messaging": {
      "TerminalStatusCache": {
        "ConfirmedQueueName": "order-confirmed-cache",
        "CancelledQueueName": "order-cancelled-cache",
        "PrefetchCount": 16,
        "ConcurrentMessageLimit": 8,
        "Retry": {
          "RetryLimit": 3,
          "MinIntervalMs": 1000,
          "MaxIntervalMs": 30000,
          "IntervalDeltaMs": 1000
        }
      },
      "ProductProjection": {
        "PrefetchCount": 32,
        "ConcurrentMessageLimit": 8,
        "Retry": {
          "RetryLimit": 3,
          "MinIntervalMs": 200,
          "MaxIntervalMs": 2000,
          "IntervalDeltaMs": 500
        }
      }
    },
    "PromotionClient": {
      "BaseAddress": "http://localhost:5040",
      "Resilience": {
        "CbSamplingDurationSeconds": 30,
        "CbMinimumThroughput": 10,
        "CbFailureRatio": 0.5,
        "CbBreakDurationSeconds": 10,
        "RetryMaxAttempts": 2,
        "AttemptTimeoutSeconds": 3,
        "TotalTimeoutSeconds": 10
      }
    }
  }
}
