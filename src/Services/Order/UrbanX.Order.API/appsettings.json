{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdentityServer": {
    "Audience": "urbanx-api"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "SaleAllocation": {
    "DefaultPerUserMax": 5
  },
  "Shipping": {
    "SupportedRegions": [
      "hanoi:badinh",
      "hanoi:caugiay",
      "hanoi:thanhxuan",
      "hochiminh:district 1",
      "hochiminh:district 7",
      "danang:haichau"
    ]
  },
  "Order": {
    "Payment": {
      "NormalOrderExpiryMinutes": 30,
      "SalesOrderExpiryMinutes": 15
    },
    "CatalogSnapshot": {
      "CacheTtlSeconds": 120,
      "HttpFallbackTimeoutMilliseconds": 300
    },
    "SaleSnapshot": {
      "MemoryCacheTtlSeconds": 10
    }
  }
}
