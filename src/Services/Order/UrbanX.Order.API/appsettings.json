{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdentityServer": {
    "Audience": "urbanx-api"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "PlaceOrder": {
    "MaxNormalPendingPerUser": 1,
    "MaxSalesPendingPerUser": 3,
    "PendingSlotTtlMinutes": 30,
    "CouponLockTtlSeconds": 960,
    "PriceMismatchTolerance": 0.01
  },
  "Shipping": {
    "SupportedRegions": [
      "hanoi:badinh",
      "hanoi:caugiay",
      "hanoi:thanhxuan",
      "hochiminh:district 1",
      "hochiminh:district 7",
      "danang:haichau"
    ]
  },
  "Order": {
    "Payment": {
      "NormalOrderExpiryMinutes": 30,
      "SalesOrderExpiryMinutes": 15
    },
    "CatalogClient": {
      "BaseAddress": "http://localhost:5290",
      "TimeoutMilliseconds": 3000
    }
  }
}
